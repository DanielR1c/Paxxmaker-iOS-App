name                 = "paxxmaker-push"
main                 = "worker.ts"
compatibility_date   = "2024-09-23"

[[kv_namespaces]]
binding = "TOKENS_KV"
id      = "YOUR_KV_NAMESPACE_ID"

[vars]
APNS_KEY_ID    = "YOUR_KEY_ID"
APNS_TEAM_ID   = "YOUR_TEAM_ID"
APNS_BUNDLE_ID = "com.yourcompany.yourapp"

# Secrets — set with CLI, never store in this file:
#   wrangler secret put APNS_PRIVATE_KEY    (paste full .p8 content)
